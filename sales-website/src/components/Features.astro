---
const features = [
  {
    icon: 'visual',
    title: 'Visual Editor',
    description: 'Drag-and-drop interface for building data pipelines. No coding required — perfect for analysts and business users.',
    color: '#6366f1'
  },
  {
    icon: 'code',
    title: 'Python API',
    description: 'Full FlowFrame API with Polars-like syntax. Same pipeline, choose your interface — visual or programmatic.',
    color: '#22c55e'
  },
  {
    icon: 'export',
    title: 'Code Generation',
    description: 'Export your visual pipelines to production-ready Python/Polars code. Zero vendor lock-in.',
    color: '#f97316'
  },
  {
    icon: 'nodes',
    title: 'Node Designer',
    description: '20+ pre-built nodes: filters, joins, aggregations, fuzzy matching. Build complex transformations visually.',
    color: '#ec4899'
  },
  {
    icon: 'speed',
    title: 'Polars Performance',
    description: '10-100x faster than Pandas. Lazy evaluation, query optimization, and memory-efficient processing.',
    color: '#06b6d4'
  },
  {
    icon: 'cloud',
    title: 'Cloud Native',
    description: 'Connect to S3, Delta Lake, Apache Iceberg, and SQL databases. Built for modern data infrastructure.',
    color: '#8b5cf6'
  }
];
---

<section id="features" class="features section">
  <div class="container">
    <div class="features-header">
      <span class="section-label">Features</span>
      <h2 class="section-title">Everything you need for data pipelines</h2>
      <p class="section-description">
        From simple data cleaning to complex ETL workflows, Flowfile gives you the tools to work the way you want.
      </p>
    </div>

    <div class="features-grid">
      {features.map((feature) => (
        <div class="feature-card">
          <div class="feature-icon" style={`--feature-color: ${feature.color}`}>
            {feature.icon === 'visual' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                <circle cx="8.5" cy="8.5" r="1.5"/>
                <polyline points="21 15 16 10 5 21"/>
              </svg>
            )}
            {feature.icon === 'code' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <polyline points="16 18 22 12 16 6"/>
                <polyline points="8 6 2 12 8 18"/>
              </svg>
            )}
            {feature.icon === 'export' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="17 8 12 3 7 8"/>
                <line x1="12" y1="3" x2="12" y2="15"/>
              </svg>
            )}
            {feature.icon === 'nodes' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="12" cy="12" r="3"/>
                <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
              </svg>
            )}
            {feature.icon === 'speed' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
              </svg>
            )}
            {feature.icon === 'cloud' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/>
              </svg>
            )}
          </div>
          <h3 class="feature-title">{feature.title}</h3>
          <p class="feature-description">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 4rem;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .feature-card {
    padding: 2rem;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    transition: all 0.3s ease;
  }

  .feature-card:hover {
    border-color: var(--feature-color, var(--color-primary));
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
  }

  .feature-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: color-mix(in srgb, var(--feature-color) 15%, transparent);
    border-radius: 10px;
    margin-bottom: 1.25rem;
  }

  .feature-icon svg {
    width: 24px;
    height: 24px;
    stroke: var(--feature-color);
  }

  .feature-title {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  .feature-description {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
