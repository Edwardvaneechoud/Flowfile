---
// FlowfileDemo.astro - Interactive demo with AG Grid
---

<section class="demo-section" id="demo">
  <div class="demo-wrapper">
    <div class="section-header">
      <span class="section-label">Try It</span>
      <h2 class="section-title">See Flowfile in action</h2>
      <p class="section-description">
        Click on each node to see how data transforms through the pipeline.
        This is real computation — no backend required.
      </p>
    </div>

    <div class="demo-container">
      <div class="window-header">
        <span class="window-dot red"></span>
        <span class="window-dot yellow"></span>
        <span class="window-dot green"></span>
        <span class="window-title">flowfile — Visual Editor</span>
      </div>

      <div class="content">
        <div class="canvas">
          <div class="nodes-container">
            <!-- SVG connections -->
            <svg class="connections" viewBox="0 0 480 160">
              <defs>
                <linearGradient id="lineGradient" x1="0%" y1="0%" x2="100%" y2="0%">
                  <stop offset="0%" stop-color="#22c55e" stop-opacity="0.5" />
                  <stop offset="50%" stop-color="#6366f1" stop-opacity="0.5" />
                  <stop offset="100%" stop-color="#ec4899" stop-opacity="0.5" />
                </linearGradient>
              </defs>
              <path class="connection-line" d="M 72 50 C 100 50, 100 50, 128 50" />
              <path class="connection-line" d="M 192 50 C 220 50, 220 50, 248 50" />
              <path class="connection-line" d="M 312 50 C 340 50, 340 50, 368 50" />
            </svg>

            <!-- Nodes -->
            <div class="node active" data-type="input" data-node="input" style="left: 20px; top: 18px;">
              <div class="node-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                  <polyline points="14 2 14 8 20 8" />
                  <line x1="16" y1="13" x2="8" y2="13" />
                  <line x1="16" y1="17" x2="8" y2="17" />
                </svg>
              </div>
              <span class="node-label">CSV Input</span>
            </div>

            <div class="node" data-type="filter" data-node="filter" style="left: 140px; top: 18px;">
              <div class="node-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                  <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3" />
                </svg>
              </div>
              <span class="node-label">Filter</span>
            </div>

            <div class="node" data-type="groupby" data-node="groupby" style="left: 260px; top: 18px;">
              <div class="node-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                  <rect x="3" y="3" width="7" height="7" rx="1" />
                  <rect x="14" y="3" width="7" height="7" rx="1" />
                  <rect x="3" y="14" width="7" height="7" rx="1" />
                  <rect x="14" y="14" width="7" height="7" rx="1" />
                </svg>
              </div>
              <span class="node-label">Group By</span>
            </div>

            <div class="node" data-type="output" data-node="output" style="left: 380px; top: 18px;">
              <div class="node-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                  <polyline points="17 8 12 3 7 8" />
                  <line x1="12" y1="3" x2="12" y2="15" />
                </svg>
              </div>
              <span class="node-label">Output</span>
            </div>
          </div>

          <div class="canvas-hint">Click a node to see its data</div>
        </div>

        <div class="data-panel">
          <div class="table-header">
            <div>
              <div class="table-title" id="table-title">Raw Data</div>
              <div class="table-subtitle" id="table-subtitle">Sales data loaded from CSV file</div>
            </div>
            <div class="table-meta" id="table-meta">8 rows × 6 cols</div>
          </div>
          <div id="transform-info" class="transform-info" style="display: none;">
            <span id="transform-badge" class="transform-badge"></span>
            <span id="transform-text"></span>
          </div>
          <div class="grid-wrapper">
            <div id="data-grid" class="ag-theme-balham"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .demo-section {
    padding: 6rem 2rem;
    background: var(--color-bg);
  }

  .demo-wrapper {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 3rem;
  }

  .section-label {
    display: inline-block;
    padding: 0.375rem 1rem;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-success);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 700;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .section-description {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .demo-container {
    background: var(--color-bg);
    border-radius: 16px;
    border: 1px solid var(--color-border);
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
  }

  .window-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 16px;
    background: var(--color-bg-elevated);
    border-bottom: 1px solid var(--color-border);
  }

  .window-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }
  .window-dot.red { background: #ff5f57; }
  .window-dot.yellow { background: #febc2e; }
  .window-dot.green { background: #28c840; }

  .window-title {
    margin-left: 12px;
    font-size: 13px;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
  }

  .content {
    display: flex;
    min-height: 420px;
  }

  .canvas {
    flex: 0 0 520px;
    position: relative;
    padding: 24px;
    background:
      radial-gradient(circle at 50% 50%, rgba(99, 102, 241, 0.03) 0%, transparent 50%),
      linear-gradient(rgba(99, 102, 241, 0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(99, 102, 241, 0.02) 1px, transparent 1px);
    background-size: 100% 100%, 40px 40px, 40px 40px;
  }

  .nodes-container {
    position: relative;
    height: 160px;
  }

  .connections {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .connection-line {
    stroke: url(#lineGradient);
    stroke-width: 2;
    fill: none;
    stroke-dasharray: 6 4;
  }

  .node {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
    cursor: pointer;
    transition: transform 0.2s ease;
  }

  .node:hover { transform: scale(1.05); }
  .node.active { transform: scale(1.08); }

  .node-icon {
    width: 64px;
    height: 64px;
    border-radius: 12px;
    background: var(--color-bg-card);
    border: 2px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
  }

  .node.active .node-icon {
    box-shadow: 0 4px 24px var(--node-color);
  }

  .node-icon svg {
    width: 28px;
    height: 28px;
    stroke-width: 1.5;
    transition: all 0.2s ease;
  }

  .node-label {
    margin-top: 10px;
    font-size: 12px;
    font-weight: 600;
    color: var(--color-text-muted);
    text-align: center;
    transition: color 0.2s ease;
  }

  .node.active .node-label { color: var(--color-text); }

  /* Node colors */
  .node[data-type="input"] { --node-color: #22c55e40; }
  .node[data-type="input"] .node-icon svg { stroke: #22c55e; }
  .node[data-type="input"].active .node-icon { background: #22c55e; border-color: #22c55e; }
  .node[data-type="input"].active .node-icon svg { stroke: white; }

  .node[data-type="filter"] { --node-color: #6366f140; }
  .node[data-type="filter"] .node-icon svg { stroke: #6366f1; }
  .node[data-type="filter"].active .node-icon { background: #6366f1; border-color: #6366f1; }
  .node[data-type="filter"].active .node-icon svg { stroke: white; }

  .node[data-type="groupby"] { --node-color: #f9731640; }
  .node[data-type="groupby"] .node-icon svg { stroke: #f97316; }
  .node[data-type="groupby"].active .node-icon { background: #f97316; border-color: #f97316; }
  .node[data-type="groupby"].active .node-icon svg { stroke: white; }

  .node[data-type="output"] { --node-color: #ec489940; }
  .node[data-type="output"] .node-icon svg { stroke: #ec4899; }
  .node[data-type="output"].active .node-icon { background: #ec4899; border-color: #ec4899; }
  .node[data-type="output"].active .node-icon svg { stroke: white; }

  .canvas-hint {
    position: absolute;
    bottom: 16px;
    left: 24px;
    font-size: 11px;
    color: #6b6b7a;
  }

  .data-panel {
    flex: 1;
    display: flex;
    flex-direction: column;
    border-left: 1px solid var(--color-border);
    background: #0d0d14;
    overflow: hidden;
  }

  .table-header {
    padding: 12px 16px;
    background: var(--color-bg-card);
    border-bottom: 1px solid var(--color-border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-shrink: 0;
  }

  .table-title {
    font-weight: 600;
    font-size: 14px;
    color: var(--color-text);
  }

  .table-subtitle {
    font-size: 12px;
    color: var(--color-text-muted);
    margin-top: 2px;
  }

  .table-meta {
    font-size: 11px;
    color: var(--color-text-muted);
    background: #0d0d14;
    padding: 4px 10px;
    border-radius: 6px;
    font-family: var(--font-mono);
  }

  .grid-wrapper {
    flex: 1;
    min-height: 300px;
  }

  #data-grid {
    width: 100%;
    height: 100%;
  }

  /* AG Grid Dark Theme */
  .ag-theme-balham {
    --ag-background-color: #12121a;
    --ag-odd-row-background-color: #12121a;
    --ag-row-background-color: #15151f;
    --ag-header-background-color: #1a1a24;
    --ag-header-foreground-color: #9090a0;
    --ag-foreground-color: #e8e8ed;
    --ag-border-color: #2a2a3a;
    --ag-secondary-foreground-color: #9090a0;
    --ag-row-hover-color: #1e1e2a;
    --ag-selected-row-background-color: #2a2a40;
    --ag-font-family: 'JetBrains Mono', monospace;
    --ag-font-size: 12px;
    --ag-header-height: 36px;
    --ag-row-height: 32px;
    --ag-cell-horizontal-padding: 12px;
  }

  .transform-info {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: var(--color-bg-elevated);
    border-bottom: 1px solid var(--color-border);
    font-size: 12px;
    color: var(--color-text-muted);
  }

  .transform-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 3px 8px;
    background: var(--color-primary);
    color: white;
    font-size: 10px;
    font-weight: 600;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .transform-badge.filter { background: #6366f1; }
  .transform-badge.groupby { background: #f97316; }
  .transform-badge.output { background: #ec4899; }

  @media (max-width: 900px) {
    .demo-section {
      padding: 4rem 1rem;
    }

    .content {
      flex-direction: column;
    }

    .canvas {
      flex: none;
      min-height: 200px;
    }

    .data-panel {
      border-left: none;
      border-top: 1px solid var(--color-border);
      min-height: 350px;
    }
  }
</style>

<script>
  // Sample data
  const RAW_DATA = [
    { id: 1, product: 'Widget A', category: 'Electronics', region: 'North', sales: 1200, quantity: 24 },
    { id: 2, product: 'Widget B', category: 'Electronics', region: 'South', sales: 890, quantity: 18 },
    { id: 3, product: 'Gadget X', category: 'Home', region: 'North', sales: 2100, quantity: 42 },
    { id: 4, product: 'Gadget Y', category: 'Home', region: 'East', sales: 760, quantity: 15 },
    { id: 5, product: 'Tool Pro', category: 'Tools', region: 'West', sales: 3200, quantity: 64 },
    { id: 6, product: 'Tool Basic', category: 'Tools', region: 'North', sales: 450, quantity: 9 },
    { id: 7, product: 'Widget C', category: 'Electronics', region: 'East', sales: 1800, quantity: 36 },
    { id: 8, product: 'Gadget Z', category: 'Home', region: 'South', sales: 920, quantity: 23 },
  ];

  // Data transformations
  function filterData(data) {
    return data.filter(row => row.sales > 1000);
  }

  function groupByData(data) {
    const grouped = data.reduce((acc, row) => {
      const key = row.category;
      if (!acc[key]) {
        acc[key] = { category: key, total_sales: 0, total_quantity: 0, count: 0 };
      }
      acc[key].total_sales += row.sales;
      acc[key].total_quantity += row.quantity;
      acc[key].count += 1;
      return acc;
    }, {});
    return Object.values(grouped);
  }

  // Node configurations
  const nodeConfigs = {
    input: {
      title: 'Raw Data',
      subtitle: 'Sales data loaded from CSV file',
      getData: () => RAW_DATA,
      columns: [
        { field: 'id', headerName: 'id', width: 70 },
        { field: 'product', headerName: 'product', flex: 1, minWidth: 100 },
        { field: 'category', headerName: 'category', width: 100 },
        { field: 'region', headerName: 'region', width: 80 },
        { field: 'sales', headerName: 'sales', width: 80, valueFormatter: p => p.value?.toLocaleString() },
        { field: 'quantity', headerName: 'quantity', width: 80 }
      ],
      transform: null
    },
    filter: {
      title: 'Filtered Data',
      subtitle: 'Rows where sales > 1000',
      getData: () => filterData(RAW_DATA),
      columns: [
        { field: 'id', headerName: 'id', width: 70 },
        { field: 'product', headerName: 'product', flex: 1, minWidth: 100 },
        { field: 'category', headerName: 'category', width: 100 },
        { field: 'region', headerName: 'region', width: 80 },
        { field: 'sales', headerName: 'sales', width: 80, valueFormatter: p => p.value?.toLocaleString() },
        { field: 'quantity', headerName: 'quantity', width: 80 }
      ],
      transform: { type: 'filter', badge: 'Filter', text: 'sales > 1000 → 5 of 8 rows pass' }
    },
    groupby: {
      title: 'Grouped Data',
      subtitle: 'Aggregated by category',
      getData: () => groupByData(filterData(RAW_DATA)),
      columns: [
        { field: 'category', headerName: 'category', flex: 1, minWidth: 100 },
        { field: 'total_sales', headerName: 'total_sales', width: 110, valueFormatter: p => p.value?.toLocaleString() },
        { field: 'total_quantity', headerName: 'total_qty', width: 100 },
        { field: 'count', headerName: 'count', width: 80 }
      ],
      transform: { type: 'groupby', badge: 'Group By', text: 'category → SUM(sales), SUM(quantity)' }
    },
    output: {
      title: 'Final Output',
      subtitle: 'Ready for export',
      getData: () => groupByData(filterData(RAW_DATA)),
      columns: [
        { field: 'category', headerName: 'category', flex: 1, minWidth: 100 },
        { field: 'total_sales', headerName: 'total_sales', width: 110, valueFormatter: p => p.value?.toLocaleString() },
        { field: 'total_quantity', headerName: 'total_qty', width: 100 },
        { field: 'count', headerName: 'count', width: 80 }
      ],
      transform: { type: 'output', badge: 'Export', text: 'Write to Parquet / CSV / Database' }
    }
  };

  let activeNode = 'input';
  let gridApi = null;

  // Load AG Grid dynamically
  function loadAgGrid() {
    return new Promise((resolve, reject) => {
      if (window.agGrid) {
        resolve();
        return;
      }

      // Load CSS
      const cssLink = document.createElement('link');
      cssLink.rel = 'stylesheet';
      cssLink.href = 'https://cdn.jsdelivr.net/npm/ag-grid-community@31.0.1/styles/ag-grid.css';
      document.head.appendChild(cssLink);

      const themeCss = document.createElement('link');
      themeCss.rel = 'stylesheet';
      themeCss.href = 'https://cdn.jsdelivr.net/npm/ag-grid-community@31.0.1/styles/ag-theme-balham.css';
      document.head.appendChild(themeCss);

      // Load JS
      const script = document.createElement('script');
      script.src = 'https://cdn.jsdelivr.net/npm/ag-grid-community@31.0.1/dist/ag-grid-community.min.js';
      script.onload = resolve;
      script.onerror = reject;
      document.head.appendChild(script);
    });
  }

  async function initDemo() {
    await loadAgGrid();

    const gridDiv = document.querySelector('#data-grid');
    const gridOptions = {
      columnDefs: nodeConfigs.input.columns,
      rowData: nodeConfigs.input.getData(),
      defaultColDef: {
        sortable: true,
        resizable: true,
      },
      animateRows: true,
      headerHeight: 36,
      rowHeight: 32,
      suppressCellFocus: true,
    };

    gridApi = agGrid.createGrid(gridDiv, gridOptions);

    // Add click handlers to nodes
    document.querySelectorAll('.node').forEach(node => {
      node.addEventListener('click', () => {
        const nodeId = node.dataset.node;
        selectNode(nodeId);
      });
    });
  }

  function selectNode(nodeId) {
    document.querySelectorAll('.node').forEach(n => n.classList.remove('active'));
    document.querySelector(`[data-node="${nodeId}"]`).classList.add('active');

    activeNode = nodeId;
    updateGrid();
  }

  function updateGrid() {
    const config = nodeConfigs[activeNode];
    const data = config.getData();
    const columns = config.columns;

    document.getElementById('table-title').textContent = config.title;
    document.getElementById('table-subtitle').textContent = config.subtitle;
    document.getElementById('table-meta').textContent = `${data.length} rows × ${columns.length} cols`;

    const transformInfo = document.getElementById('transform-info');
    if (config.transform) {
      transformInfo.style.display = 'flex';
      document.getElementById('transform-badge').textContent = config.transform.badge;
      document.getElementById('transform-badge').className = `transform-badge ${config.transform.type}`;
      document.getElementById('transform-text').textContent = config.transform.text;
    } else {
      transformInfo.style.display = 'none';
    }

    if (gridApi) {
      gridApi.setGridOption('columnDefs', columns);
      gridApi.setGridOption('rowData', data);
    }
  }

  // Initialize when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDemo);
  } else {
    initDemo();
  }
</script>
