{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "loading-capability",
  "description": "Capabilities granted to the loading splash window",
  "windows": ["loading"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-listen",
    "core:window:allow-close",
    "core:app:allow-version"
  ]
}
