  "description": "A tool for designing and executing data flows",
  "scripts": {
    "dev": "tauri dev",
    "dev:web": "vite --config vite.config.mjs",
    "build": "npm run lint && vue-tsc --noEmit && tauri build",
    "build:web": "npm run lint && vue-tsc --noEmit && vite build --config vite.config.mjs",
    "build:renderer-only": "vite build --config vite.config.mjs",
    "preview:web": "vite preview",
    "lint": "eslint --fix ./src/**/*.{ts,vue}",
    "tauri": "tauri",
    "tauri:build:debug": "tauri build --debug",
    "test:web": "playwright test tests/web-flow.spec.ts",
    "test:all": "playwright test",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:unit:watch": "vitest --config vitest.config.ts"
  },
